# ─── OKX API ────────────────────────────────────────────────────────────────
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_api_secret_here
OKX_PASSPHRASE=your_passphrase_here

# Set to "true" to use OKX demo/paper trading environment
OKX_IS_DEMO=false

# ─── Bark Push Notifications ─────────────────────────────────────────────────
BARK_KEY=your_bark_device_key_here
BARK_SERVER=https://api.day.app

# ─── Data ────────────────────────────────────────────────────────────────────
# Local Parquet catalog path
DATA_CATALOG_PATH=./data/catalog

# ─── Database (production only) ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:password@localhost:5432/cyber_trader

# ─── Trading ─────────────────────────────────────────────────────────────────
# Trading mode: backtest | paper | live
TRADING_MODE=paper

# Trader ID
TRADER_ID=CYBER-TRADER-001

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
